# 이 파일을 복사해서 ".env" 라는 이름으로 저장한 뒤 값을 채워주세요.
# (.env 파일은 절대 외부에 공유하거나 깃허브 등에 올리지 마세요)

# Anthropic Claude API 키 (https://console.anthropic.com 에서 발급)
ANTHROPIC_API_KEY=

# 사용할 모델 (기본값 그대로 두셔도 됩니다)
ANTHROPIC_MODEL=claude-sonnet-4-5

# Flask 세션 암호화 키 (아무 임의의 긴 문자열로 변경 권장)
FLASK_SECRET_KEY=change-this-to-a-random-string

# 서버 포트 (필요시 변경)
PORT=8000

# 식약처 RSS 자동 동기화 (결재/API키 불필요, 무료 공식 RSS만 사용)
MFDS_SYNC_ENABLED=true
MFDS_SYNC_INTERVAL_MINUTES=30
